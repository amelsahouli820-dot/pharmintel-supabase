generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  DIRECTOR_GENERAL
  SUPERVISOR
  DELEGATE
}

enum UserStatus {
  PENDING
  ACTIVE
  INACTIVE
  SUSPENDED
  REFUSED
  ARCHIVED
  DELETED
}

enum DocumentStatus {
  WAITING_AI
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum DocumentType {
  FLASH_SALE
  RESTOCK
  COMMERCIAL_PROPOSAL
  QUOTA
  PROMOTION
  CONVENTION
  REBATE
  EXCEPTIONAL_DISCOUNT
  PRICING
  CATALOG
  STOCKOUT
  PRODUCT_LAUNCH
  COMMERCIAL_COMMUNICATION
  LAB_INFORMATION
  LETTER
  EMAIL
  OTHER
}

enum ConfidentialityLevel {
  INTERNAL
  CONFIDENTIAL
  HIGHLY_CONFIDENTIAL
}

enum PriorityLevel {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ReviewStatus {
  PENDING
  PENDING_AI
  NEEDS_REVIEW
  MODIFIED
  VALIDATED
  REJECTED
  ARCHIVED
}

enum InformationSourceKind {
  FILE
  MANUAL
}

enum ReferenceEntityType {
  WHOLESALER
  LABORATORY
  HEALTH_ESTABLISHMENT
  PHARMACY
  SUPPLIER
  COMPETITOR
  OTHER
}

enum SignalStatus {
  EMERGING
  CONFIRMED
  CONTRADICTORY
  TREND
}

enum OfferType {
  OFFER
  PROMOTION
  FLASH_SALE
  RESTOCK
  DISCOUNT
  NEW_PRODUCT
  OTHER
}

enum AlertType {
  NEW_OFFER
  FLASH_SALE
  HIGH_DISCOUNT
  NEW_PRODUCT
  PROCESSING_FAILED
  USER_REGISTRATION_REQUEST
  NEW_FIELD_INFORMATION
  DOCUMENT_VALIDATED
  DOCUMENT_REJECTED
  DOCUMENT_MODIFIED
  ACCOUNT_ACCEPTED
  ACCOUNT_REFUSED
  ROLE_CHANGED
  PASSWORD_RESET
  SECURITY_LOGIN_FAILED
  NEW_MESSAGE
  SYSTEM_ANNOUNCEMENT
  DOCUMENT_IMPORTED
  INFORMATION_PENDING
  IMPORT_ERROR
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum ProcessingJobStatus {
  QUEUED
  RUNNING
  BLOCKED
  COMPLETED
  FAILED
}

model User {
  id                 String       @id @default(cuid())
  name               String
  firstName          String?
  lastName           String?
  jobTitle           String?
  service            String?
  email              String       @unique
  personalEmail      String?
  phone              String?
  personalPhone      String?
  messagingApps      String[]      @default([])
  notificationPreferences Json    @default("{\"professionalEmail\":true,\"personalEmail\":false,\"whatsapp\":false,\"viber\":false,\"telegram\":false,\"sms\":false}")
  urgentAlerts       Boolean      @default(false)
  avatarStorageKey   String?
  avatarMime         String?
  passwordHash       String
  deletedAt          DateTime?
  archivedAt         DateTime?
  archiveReason      String?
  previousRole       Role?
  role               Role         @default(DELEGATE)
  status             UserStatus   @default(ACTIVE)
  supervisorId       String?
  region             String?
  wilaya             String?
  supervisor         User?        @relation("UserSupervision", fields: [supervisorId], references: [id], onDelete: SetNull)
  delegates          User[]       @relation("UserSupervision")
  mustChangePassword Boolean      @default(true)
  sessionVersion     Int          @default(0)
  permissions        Json         @default("{\"canImport\":true,\"canUseAI\":true,\"canExport\":true}")
  lastLoginAt        DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  documents          Document[]   @relation("DocumentAuthor")
  assignedDocuments  Document[]   @relation("DocumentAssignee")
  records            IntelligenceRecord[]
  alerts             Alert[]
  auditLogs          AuditLog[]   @relation("AuditActor")
  attachments        Attachment[]
  documentComments   DocumentComment[]
  scoreEvents        ScoreEvent[] @relation("ScoreRecipient")
  awardedScoreEvents ScoreEvent[] @relation("ScoreAwarder")
  validations        DocumentValidation[]
  confirmations      SignalConfirmation[]
  documentConfirmations DocumentConfirmation[]
  sessions            Session[]
  sentMessages        Message[] @relation("MessageSender")
  receivedMessages    Message[] @relation("MessageRecipient")

  @@index([status, role])
  @@index([status, archivedAt])
  @@index([supervisorId])
  @@map("users")
}

model Document {
  id           String                  @id @default(cuid())
  userId       String
  user         User                    @relation("DocumentAuthor", fields: [userId], references: [id], onDelete: Restrict)
  assignedToId String?
  assignedTo   User?                   @relation("DocumentAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  originalName String
  storageKey   String                  @unique
  mimeType     String
  size         Int
  sha256       String
  status       DocumentStatus          @default(PENDING)
  reviewStatus ReviewStatus             @default(PENDING)
  sourceKind   InformationSourceKind    @default(FILE)
  fieldSource  String?
  entityType   ReferenceEntityType      @default(WHOLESALER)
  entityName   String?
  wilaya       String?
  confidenceLevel Int?
  isStrategic  Boolean                  @default(false)
  wholesaler   String?
  customWholesaler String?
  documentType DocumentType             @default(OTHER)
  customDocumentType String?
  documentDate DateTime?
  receivedAt   DateTime?
  region       String?
  laboratory   String?
  comments     String?                  @db.Text
  confidentiality ConfidentialityLevel @default(INTERNAL)
  priority     PriorityLevel            @default(NORMAL)
  errorMessage String?
  rawText      String?                 @db.Text
  processedAt  DateTime?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  records      IntelligenceRecord[]
  processingJob ProcessingJob?
  attachments  Attachment[]
  documentComments DocumentComment[]
  scoreEvents  ScoreEvent[]
  validations  DocumentValidation[]
  signalConfirmations SignalConfirmation[]
  confirmations DocumentConfirmation[] @relation("CanonicalDocumentConfirmations")

  @@index([userId, createdAt])
  @@index([assignedToId, createdAt])
  @@index([status, createdAt])
  @@index([documentType, createdAt])
  @@index([wholesaler, createdAt])
  @@map("documents")
}

model ProcessingJob {
  id          String              @id @default(cuid())
  documentId  String              @unique
  document    Document            @relation(fields: [documentId], references: [id], onDelete: Cascade)
  status      ProcessingJobStatus @default(QUEUED)
  attempts    Int                 @default(0)
  lockedAt    DateTime?
  errorMessage String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([status, createdAt])
  @@map("processing_jobs")
}

model Attachment {
  id           String   @id @default(cuid())
  documentId   String
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  originalName String
  storageKey   String   @unique
  mimeType     String
  size         Int
  createdAt    DateTime @default(now())

  @@index([documentId, createdAt])
  @@map("attachments")
}

model DocumentComment {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content    String   @db.Text
  createdAt  DateTime @default(now())

  @@index([documentId, createdAt])
  @@map("document_comments")
}

model ScoreEvent {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("ScoreRecipient", fields: [userId], references: [id], onDelete: Cascade)
  documentId  String?
  document    Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  awardedById String?
  awardedBy   User?     @relation("ScoreAwarder", fields: [awardedById], references: [id], onDelete: SetNull)
  points      Int
  reason      String
  details     String?
  createdAt   DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([documentId])
  @@map("score_events")
}

model ReferenceEntity {
  id        String              @id @default(cuid())
  type      ReferenceEntityType
  name      String
  aliases   String[]
  active    Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([type, name])
  @@index([type, active])
  @@map("reference_entities")
}

model DocumentValidation {
  id             String   @id @default(cuid())
  documentId     String
  document       Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment        String?  @db.Text
  attachmentName String?
  attachmentKey  String?
  attachmentMime String?
  attachmentSize Int?
  createdAt      DateTime @default(now())

  @@index([documentId, createdAt])
  @@map("document_validations")
}

model InformationSignal {
  id                String       @id @default(cuid())
  fingerprint       String       @unique
  wholesaler        String?
  laboratory        String?
  product           String
  offerType         OfferType
  status            SignalStatus @default(EMERGING)
  confirmationCount Int          @default(1)
  reliabilityScore  Int          @default(40)
  firstSeenAt       DateTime     @default(now())
  lastSeenAt        DateTime     @default(now())
  records           IntelligenceRecord[]
  confirmations     SignalConfirmation[]

  @@index([status, reliabilityScore])
  @@index([wholesaler])
  @@index([laboratory])
  @@index([product])
  @@map("information_signals")
}

model SignalConfirmation {
  id         String             @id @default(cuid())
  signalId   String
  signal     InformationSignal  @relation(fields: [signalId], references: [id], onDelete: Cascade)
  documentId String
  document   Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  recordId   String?
  record     IntelligenceRecord? @relation(fields: [recordId], references: [id], onDelete: SetNull)
  userId     String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  region     String?
  wilaya     String?
  createdAt  DateTime           @default(now())

  @@unique([signalId, documentId, userId])
  @@index([signalId, createdAt])
  @@index([wilaya])
  @@map("signal_confirmations")
}

model DocumentConfirmation {
  id                  String   @id @default(cuid())
  canonicalDocumentId String
  canonicalDocument   Document @relation("CanonicalDocumentConfirmations", fields: [canonicalDocumentId], references: [id], onDelete: Cascade)
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  region              String?
  wilaya              String?
  comment              String?
  createdAt            DateTime @default(now())

  @@unique([canonicalDocumentId, userId])
  @@index([canonicalDocumentId, createdAt])
  @@map("document_confirmations")
}

model IntelligenceRecord {
  id              String      @id @default(cuid())
  documentId      String
  document        Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  signalId        String?
  signal          InformationSignal? @relation(fields: [signalId], references: [id], onDelete: SetNull)
  observedAt      DateTime?
  wholesaler      String?
  laboratory     String?
  product         String
  productRange    String?
  molecule        String?
  therapeuticClass String?
  productCode     String?
  cip             String?
  price           Decimal?    @db.Decimal(14, 2)
  priceHt         Decimal?    @db.Decimal(14, 2)
  priceTtc        Decimal?    @db.Decimal(14, 2)
  promotionalPrice Decimal?  @db.Decimal(14, 2)
  currency        String      @default("DZD")
  offerType       OfferType   @default(OTHER)
  discountPercent Decimal?    @db.Decimal(5, 2)
  freeUnits       Int?
  quota           String?
  commercialConditions String? @db.Text
  startsAt        DateTime?
  endsAt          DateTime?
  wilaya          String?
  city            String?
  region          String?
  salesperson     String?
  distributionChannel String?
  comments        String?     @db.Text
  confidence      Float       @default(0)
  rawExtraction   Json
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  alerts          Alert[]
  signalConfirmations SignalConfirmation[]

  @@index([userId, createdAt])
  @@index([signalId])
  @@index([observedAt])
  @@index([wholesaler])
  @@index([laboratory])
  @@index([product])
  @@index([molecule])
  @@index([therapeuticClass])
  @@index([offerType])
  @@index([wilaya])
  @@map("intelligence_records")
}

model Alert {
  id        String               @id @default(cuid())
  userId    String
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  recordId  String?
  record    IntelligenceRecord?  @relation(fields: [recordId], references: [id], onDelete: Cascade)
  type      AlertType
  severity  AlertSeverity        @default(INFO)
  title     String
  message   String
  readAt    DateTime?
  createdAt DateTime             @default(now())

  @@index([userId, readAt, createdAt])
  @@map("alerts")
}

model Session {
  id         String   @id @default(cuid())
  tokenId    String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?

  @@index([userId, revokedAt, expiresAt])
  @@map("sessions")
}

model Message {
  id          String   @id @default(cuid())
  senderId    String
  sender      User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipientId String
  recipient   User     @relation("MessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  subject     String
  content     String   @db.Text
  documentId  String?
  readAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([recipientId, readAt, createdAt])
  @@index([senderId, createdAt])
  @@map("messages")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
