generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum DocumentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum OfferType {
  OFFER
  PROMOTION
  FLASH_SALE
  RESTOCK
  DISCOUNT
  NEW_PRODUCT
  OTHER
}

enum AlertType {
  NEW_OFFER
  FLASH_SALE
  HIGH_DISCOUNT
  NEW_PRODUCT
  PROCESSING_FAILED
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum ProcessingJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

model User {
  id                 String       @id @default(cuid())
  name               String
  email              String       @unique
  passwordHash       String
  role               Role         @default(USER)
  status             UserStatus   @default(ACTIVE)
  mustChangePassword Boolean      @default(true)
  sessionVersion     Int          @default(0)
  permissions        Json         @default("{\"canImport\":true,\"canUseAI\":true,\"canExport\":true}")
  lastLoginAt        DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  documents          Document[]
  records            IntelligenceRecord[]
  alerts             Alert[]
  auditLogs          AuditLog[]   @relation("AuditActor")

  @@index([status, role])
  @@map("users")
}

model Document {
  id           String                  @id @default(cuid())
  userId       String
  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalName String
  storageKey   String                  @unique
  mimeType     String
  size         Int
  sha256       String
  status       DocumentStatus          @default(PENDING)
  errorMessage String?
  rawText      String?                 @db.Text
  processedAt  DateTime?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  records      IntelligenceRecord[]
  processingJob ProcessingJob?

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("documents")
}

model ProcessingJob {
  id          String              @id @default(cuid())
  documentId  String              @unique
  document    Document            @relation(fields: [documentId], references: [id], onDelete: Cascade)
  status      ProcessingJobStatus @default(QUEUED)
  attempts    Int                 @default(0)
  lockedAt    DateTime?
  errorMessage String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([status, createdAt])
  @@map("processing_jobs")
}

model IntelligenceRecord {
  id              String      @id @default(cuid())
  documentId      String
  document        Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  observedAt      DateTime?
  wholesaler      String?
  laboratory     String?
  product         String
  price           Decimal?    @db.Decimal(14, 2)
  currency        String      @default("DZD")
  offerType       OfferType   @default(OTHER)
  discountPercent Decimal?    @db.Decimal(5, 2)
  wilaya          String?
  region          String?
  comments        String?     @db.Text
  confidence      Float       @default(0)
  rawExtraction   Json
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  alerts          Alert[]

  @@index([userId, createdAt])
  @@index([observedAt])
  @@index([wholesaler])
  @@index([laboratory])
  @@index([product])
  @@index([offerType])
  @@index([wilaya])
  @@map("intelligence_records")
}

model Alert {
  id        String               @id @default(cuid())
  userId    String
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  recordId  String?
  record    IntelligenceRecord?  @relation(fields: [recordId], references: [id], onDelete: Cascade)
  type      AlertType
  severity  AlertSeverity        @default(INFO)
  title     String
  message   String
  readAt    DateTime?
  createdAt DateTime             @default(now())

  @@index([userId, readAt, createdAt])
  @@map("alerts")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
