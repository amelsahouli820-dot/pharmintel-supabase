# Application
NODE_ENV=development
APP_URL=http://localhost:3000
# Laisser vide : activé automatiquement lorsque APP_URL commence par https://
COOKIE_SECURE=
JWT_SECRET=change-me-with-at-least-32-random-characters
MAX_UPLOAD_MB=25
DISCOUNT_ALERT_THRESHOLD=25

# PostgreSQL / Redis
POSTGRES_PASSWORD=change-this-database-password
DATABASE_URL=postgresql://pharmintel:change-this-database-password@postgres:5432/pharmintel?schema=public
REDIS_URL=redis://redis:6379

# Object storage (AWS S3 or compatible MinIO)
S3_ENDPOINT=http://minio:9000
S3_REGION=eu-west-1
S3_BUCKET=pharmintel-documents
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change-this-secret
S3_FORCE_PATH_STYLE=true

# Artificial intelligence
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Initial administrator (used only by prisma seed)
ADMIN_NAME=Administrateur
ADMIN_EMAIL=admin@pharmintel.dz
ADMIN_PASSWORD=ChangeMe!2026
